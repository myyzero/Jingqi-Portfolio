{
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "cookie",
          "key": "lang",
          "value": "zh"
        }
      ],
      "destination": "/zh",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        {
          "type": "cookie",
          "key": "lang",
          "value": "en"
        }
      ],
      "destination": "/en",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "CN"
        }
      ],
      "destination": "/zh",
      "permanent": false
    },
    {
      "source": "/",
      "destination": "/en",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/(en|zh)",
      "destination": "/"
    },
    {
      "source": "/(en|zh)/(.*)",
      "destination": "/"
    }
  ]
}

